{
  "name": "openclaw-monitor",
  "version": "0.1.0",
  "description": "OpenClaw Gateway Monitor",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": "./dist/index.js",
  "bin": {
    "openclaw-monitor": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
