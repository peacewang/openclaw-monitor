    "@types/pidusage": "^2.0.5",
    "chart.js": "^4.5.1",
    "commander": "^12.1.0",
    "eslint": "^8.56.0",
    "memfs": "^4.56.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
