{
  "name": "openclaw-monitor",
  "version": "0.1.0",
  "description": "OpenClaw Gateway Monitor",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "openclaw-monitor": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli/index.js",
    "start:dev": "node dist/cli/index.js start --dev",
    "test": "vitest",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/static": "^6.0.0",
    "@fastify/websocket": "^11.0.0",
    "fastify": "^5.3.0",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "pidusage": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pidusage": "^2.0.5",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "web",
    "config.example.json"
  ]
}
